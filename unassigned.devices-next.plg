<!--
Get the plugin bundle.
-->
<FILE Name="/boot/config/plugins/&plugin;/&name;-&version;.tgz">
<URL>"&tgzURL;/&name;-&version;.tgz"</URL>
<MD5>&MD5;</MD5>
</FILE>

<!--
The 'pre-install' script.
-->
<FILE Run="/bin/bash">
<INLINE>
#
# The previous unassigned devices plugin cannot be installed.
#
if [ -f /var/log/plugins/&plugin;.plg ] ; then
echo ""
echo "-----------------------------------------------------------"
echo " &name; has not been installed!"
echo ""
echo " The previous Unassigned Devices plugin is installed."
echo ""
echo " You must uninstall the Unassigned Devices plugin"
echo " before installing Unassigned Devices - Next."
echo ""
echo "-----------------------------------------------------------"
echo ""
exit 1
fi

#
# Remove emhttp files so we can re-install.
#
rm -rf /usr/local/emhttp/plugins/&plugin;/* 2>/dev/null

#
# Remove old 'bundle' files.
#
rm -f $(ls /boot/config/plugins/&plugin;/*.tgz 2>/dev/null | grep -v '&version;')

#
# Remove old add-smb file
#
rm -f /tmp/&plugin;/add-smb
</INLINE>
</FILE>

<FILE Name="/boot/config/plugins/&plugin;/&plugin;.cfg">
<INLINE>
<![CDATA[
common_cmd=""
destructive_mode=""
luks_volume=""
automount_usb=""
NFS_Export=""
NFS_Security=""
NFS_Version=0
nfs_rule=""
SMB_Sharing=""
SMB_Version=""
SMB1_Fallback=""
discard=""
force_user=""
symlinks=""
case_names=""
debug_level=0
zvols=""
remote_share_wait=""
time_machine=""
time_mach_vol_size=""
]]>
</INLINE>
</FILE>

<FILE Name="/boot/config/plugins/&plugin;/samba_mount.cfg">
<INLINE>
<![CDATA[
]]>
</INLINE>
</FILE>

<FILE Name="/boot/config/plugins/&plugin;/iso_mount.cfg">
<INLINE>
<![CDATA[
]]>
</INLINE>
</FILE>

<!--
Add smb parameters for UD.
-->
<FILE Name="/tmp/&plugin;/add-smb" Mode="0770">
<INLINE>
<![CDATA[
#!/bin/bash
#
# Remove the unused legacy smb-extra.conf entries
#
if [ -f /boot/config/smb-extra.conf ] ; then
	if [[ `/usr/bin/grep '#unassigned_devices' /boot/config/smb-extra.conf 2> /dev/null` != "" ]]; then
		/usr/bin/sed '/#unassigned_devices_start/,/#unassigned_devices_end/d' /boot/config/smb-extra.conf > /tmp/smb.tmp
		mv /tmp/smb.tmp /boot/config/smb-extra.conf
	fi

	#
	# Remove vfs_objects from smb-extra.conf because it messes up a lot of stuff
	#
	sed -i 's/^[[:space:]]*vfs objects.*/#DO NOT ADD vfs objects HERE - IT BREAKS UD, RECYCLE BIN, AND MACOS SETTING/' /boot/config/smb-extra.conf
fi

#
# Add entry to /etc/samba/smb.conf
#
if [[ `grep '# hook for unassigned devices shares' /etc/samba/smb.conf` = "" ]]; then
	sed -i "/# auto-configured shares/i \[global]\n	# hook for unassigned devices shares\n	include = /etc/samba/smb-unassigned.conf\n" /etc/samba/smb.conf
fi

if [ -e /tmp/unassigned.devices/smb-settings.conf ]; then
	#
	# Move the previous smb-settings.conf file
	#
	mv /tmp/unassigned.devices/smb-settings.conf /etc/samba/smb-unassigned.conf
fi

#
# Reload samba
#
/usr/bin/smbcontrol all reload-config 2>&1
sleep 1

#
# Start wsdd2 using Unraid's system script for compatibility
#
if ! /usr/bin/pgrep -x wsdd2 >/dev/null 2>&1; then
	/etc/rc.d/rc.wsdd2 start >/dev/null 2>&1
fi
]]>
</INLINE>
</FILE>

<!--
The 'post-install' script.
-->
<FILE Run="/bin/bash">
<INLINE>
#
# Create logs, config, and device scripts directory.
#
mkdir -p /tmp/&plugin;/logs /tmp/&plugin;/config /tmp/&plugin;/scripts

#
# Create smb-unassigned.conf if it does not exist
#
touch /etc/samba/smb-unassigned.conf

#
# Create plugin directory
#
mkdir -p /boot/config/plugins/&plugin;

#
# Install the 'bundle'.
#
tar -xf /boot/config/plugins/&plugin;/&name;-&version;.tgz -C /usr/local/emhttp/plugins 2>/dev/null

#
# Move the rules file
#
mv /usr/local/emhttp/plugins/&plugin;/99_persistent_unassigned.rules /etc/udev/rules.d/
chmod 644 -R /etc/udev/rules.d/99_persistent_unassigned.rules 2>/dev/null

#
# Create a symlink to rm.
#
ln -sf /bin/rm /usr/local/emhttp/plugins/&plugin;/scripts/

#
# Fix permissions of executable files
#
chmod +x /usr/local/emhttp/plugins/&plugin;/scripts/* /usr/local/emhttp/plugins/&plugin;/event/*

#
# Create a symlink to unassigned devices scripts.
#
ln -sf /usr/local/emhttp/plugins/&plugin;/scripts/rc.unassigned /usr/local/sbin
ln -sf /usr/local/emhttp/plugins/&plugin;/scripts/mkmbr.sh /usr/local/sbin
ln -sf /usr/local/emhttp/plugins/&plugin;/scripts/ud_diagnostics /usr/local/sbin

#
# Create state folder and mount points
#
mkdir -p /mnt/disks/ /mnt/remotes/ /mnt/addons/ /mnt/rootshare/ /var/state/&plugin;/

#
# Create a tmpfs mountpoint at /mnt/disks
# to make sure that writting to an unmounted device doesn't fill all rootfs
# ps: tmpfs mountpoint will only be created if no disks are mounted yet
#
mounted_disks="n"
if ! mountpoint -q /mnt/disks 2>/dev/null; then
  for dir in /mnt/disks/*; do 
    if mountpoint -q "$dir" 2>/dev/null; then 
      mounted_disks="y" 
    fi
  done
  if [ $mounted_disks == "n" ]; then
    mount -t tmpfs -o size=1M tmpfs /mnt/disks
  else
    touch /var/state/&plugin;/reboot_required
  fi
fi
chown nobody:users /mnt/disks

#
# Create a tmpfs mountpoint at /mnt/remotes
# to make sure that a CIFS connection dropout doesn't fill all rootfs
# ps: tmpfs mountpoint will only be created if no remote mounts are mounted yet
#
mounted_remotes="n"
if ! mountpoint -q /mnt/remotes 2>/dev/null; then
  for dir in /mnt/remotes/*; do 
    if mountpoint -q "$dir" 2>/dev/null; then 
      mounted_remotes="y" 
    fi
  done
  if [ $mounted_remotes == "n" ]; then
    mount -t tmpfs -o size=1M tmpfs /mnt/remotes
  else
    touch /var/state/&plugin;/reboot_required
  fi
fi
chown nobody:users /mnt/remotes

#
# Create a tmpfs mountpoint at /mnt/addons
# to make sure that writting to an unmounted device doesn't fill all rootfs
# ps: tmpfs mountpoint will only be created if no addons are mounted yet
#
mounted_addons="n"
if ! mountpoint -q /mnt/addons 2>/dev/null; then
  for dir in /mnt/addons/*; do 
    if mountpoint -q "$dir" 2>/dev/null; then 
      mounted_addons="y" 
    fi
  done
  if [ $mounted_addons == "n" ]; then
    mount -t tmpfs -o size=1M tmpfs /mnt/addons
  else
    touch /var/state/&plugin;/reboot_required
  fi
fi
chown nobody:users /mnt/addons

#
# Create a tmpfs mountpoint at /mnt/rootshare
# to make sure that a CIFS connection dropout doesn't fill all rootfs
# ps: tmpfs mountpoint will only be created if no rootshare mounts are mounted yet
#
mounted_rootshare="n"
if ! mountpoint -q /mnt/rootshare 2>/dev/null; then
  for dir in /mnt/rootshare/*; do 
    if mountpoint -q "$dir" 2>/dev/null; then 
      mounted_rootshare="y" 
    fi
  done
  if [ $mounted_rootshare == "n" ]; then
    mount -t tmpfs -o size=1M tmpfs /mnt/rootshare
  else
    touch /var/state/&plugin;/reboot_required
  fi
fi
chown nobody:users /mnt/rootshare

#
# Add unassigned_devices to smb.conf.
#
at -f "/tmp/&plugin;/add-smb" "now" 2>/dev/null

#
# Copy config files to the tmp file system to be sure we have current settings.
#
/usr/bin/cp /boot/config/plugins/&plugin;/*.cfg /tmp/&plugin;/config/ 2>/dev/null

#
# Apply settings to update share settings and copy configuration files to tmp file system.
#
/usr/local/emhttp/plugins/&plugin;/scripts/rc.settings apply 2>/dev/null

#
# Rename original Dynamix page
#
if [[ -e /usr/local/emhttp/plugins/dynamix/OpenDevices.page ]]; then
  mv -f /usr/local/emhttp/plugins/dynamix/OpenDevices.page /usr/local/emhttp/plugins/dynamix/OpenDevices.page-
fi

#
# Clean out old plugin packages
#
find /boot/config/plugins/&plugin; -type f -iname "&name;*.txz" ! -iname "*&version;*" -delete
find /boot/config/plugins/&plugin; -type f -iname "&name;*.md5" ! -iname "*&version;*" -delete

#
# reload udev rules
#
udevadm control --reload-rules

#
# Load the ntfs3 module if it is available
#
modprobe ntfs3 2>/dev/null

#
# Update the file 'update.php' if version is 6.11, or 6.12 so device script 'Apply' changes will work.
# Get the Unraid version
#
unraid_version=$(cat /etc/unraid-version)

#
# Extract the first 4 characters of the version
# Read the Unraid version from the file
#
source '/etc/unraid-version'
first_four_chars=${version:0:4}

#
# These are some temporary patches to overcome several issues
#
# Update the update.php file so device settings will save the script correctly
# Check if the first 4 characters are 6.11 or 6.12
#
if [[ $first_four_chars == "6.11" || $first_four_chars == "6.12" ]]; then
	cp /usr/local/emhttp/plugins/&plugin;/include/update.php /usr/local/emhttp/update.php
else
	rm /usr/local/emhttp/plugins/&plugin;/include/update.php
fi

echo ""
echo "-----------------------------------------------------------"
echo " &name; has been installed."
echo " Copyright 2016-2026, &author;"
echo " Version: &version;"
echo ""
echo " Note:"
echo " Install the Unassigned Devices Plus - Next plugin to extend"
echo " Unassigned Devices support for additional disk formats including"
echo " HFS+, exFAT, and APFS, and enable destructive mode for advanced"
echo " disk operations such as formatting and disk preparation."
echo ""
echo " Support for formatting disks is included in Unraid 7.2 and"
echo " later."
if [ -f /var/state/&plugin;/reboot_required ]; then
  echo ""
  echo " PLEASE REBOOT YOUR SERVER "
  echo ""
fi
echo "-----------------------------------------------------------"
echo ""
</INLINE>
</FILE>

<!--
The 'remove' script.
-->
<FILE Run="/bin/bash" Method="remove">
<INLINE>
#
# umount disks and smb mounts
#
/usr/local/emhttp/plugins/&plugin;/scripts/rc.unassigned umount all 2>/dev/null

if mountpoint -q "/mnt/disks"; then
  umount "/mnt/disks"
fi
rmdir /mnt/disks 2>/dev/null

if mountpoint -q "/mnt/remotes"; then
  umount "/mnt/remotes"
fi
rmdir /mnt/remotes 2>/dev/null

if mountpoint -q "/mnt/addons"; then
  umount "/mnt/addons"
fi
rmdir /mnt/addons 2>/dev/null

if mountpoint -q "/mnt/rootshare"; then
  umount "/mnt/rootshare"
fi
rmdir /mnt/rootshare 2>/dev/null

rm -f /tmp/plugins/&plugin;.plg \
      /usr/local/sbin/rc.unassigned \
	  /usr/local/sbin/mkmbr.sh \
      /etc/udev/rules.d/99_persistent_unassigned.rules

#
# Reload udev rules
#
udevadm control --reload-rules

#
# Restore original Dynamix page
#
mv -f /usr/local/emhttp/plugins/dynamix/OpenDevices.page- /usr/local/emhttp/plugins/dynamix/OpenDevices.page

#
# Remove all plugin files from emhttp.
#
rm -rf /usr/local/emhttp/plugins/&plugin; 2>/dev/null

#
# Remove plugin related directories
#
rm -rf	/var/state/&plugin;/ \
		/tmp/&plugin;/

#
# Remove the unassigned devices 'bundle' so it will be downloaded if re-installed.
#
rm -rf /boot/config/plugins/&plugin;/&name;-&version;.tgz

echo ""
echo "-----------------------------------------------------------"
echo " &name; has been uninstalled."
echo "-----------------------------------------------------------"
echo ""
</INLINE>
</FILE>

</PLUGIN>
