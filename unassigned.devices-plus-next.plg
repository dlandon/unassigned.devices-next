<?xml version='1.0' standalone='yes'?>
<!DOCTYPE PLUGIN [
<!ENTITY name		"unassigned.devices-plus-next">
<!ENTITY plugin		"unassigned.devices-plus">
<!ENTITY author		"dlandon">
<!ENTITY version	"2026.03.27">
<!ENTITY launch		"Main/UnassignedDevices">
<!ENTITY gitURL		"https://raw.githubusercontent.com/&author;/unassigned.devices-next/master;">
<!ENTITY pluginURL	"&gitURL;/&name;.plg">
<!ENTITY supportURL	"https://github.com/dlandon/unassigned.devices-next/discussions/">
<!ENTITY packages	"/boot/config/plugins/&plugin;/packages">
]>

<PLUGIN name="&plugin;"
		author="&author;"
		launch="&launch;"
		version="&version;"
		pluginURL="&pluginURL;"
		support="&supportURL;"
		icon="unlink"
		min="6.12.0">

<CHANGES>
##&name;
###&version;
- Notice: Initial release under the new license.
- Fix: Minimum Unraid version changed to 6.12.
- Fix: Don't remove parted package since Unraid 7 installs it and uses it.
- Fix: Replace exfat-utils and fuse-exfat packages with exfatprogs when running Unraid 7.2.0.
- Fix: Support for exFat disks was added in 7.2.  Adjustments made for 6.12 and 7.0 to support exFat disks.
</CHANGES>

