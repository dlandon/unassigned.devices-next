<!--
README.md
-->
<FILE Name="/usr/local/emhttp/plugins/&plugin;/README.md">
<INLINE>
<![CDATA[
**Unassigned Devices Plus - Next**

This plugin extends Unassigned Devices support for additional disk formats including HFS+, exFAT, and APFS, and enables destructive mode for advanced disk operations such as formatting and disk preparation.

Originally developed and maintained by Dan Landon.

Project repository, documentation, and license information are available on GitHub.
]]>
</INLINE>
</FILE>

<!--
The 'post-install' script.
-->
<FILE Run="/bin/bash">
<INLINE>
#
# Copy Unassigned Devices License
#
cp /usr/local/emhttp/plugins/unassigned.devices/LICENSE.md /usr/local/emhttp/plugins/&plugin;/LICENSE.md

#
# Set up EXFAT utility symlinks for UD
#
UD_EXFAT_DIR="/usr/local/sbin/ud-exfat"

#
# Required EXFAT utilities
#
EXFAT_TOOLS=(
	"mkfs.exfat"
	"fsck.exfat"
	"exfatlabel"
)

#
# Search paths in preferred order
#
SEARCH_PATHS=(
	"/sbin"
	"/usr/sbin"
)

#
# Create shim directory
#
if [ ! -d "${UD_EXFAT_DIR}" ]; then
	mkdir -p "${UD_EXFAT_DIR}"
fi

#
# Resolve and link tools
#
for tool in "${EXFAT_TOOLS[@]}"; do
	found=""

	for path in "${SEARCH_PATHS[@]}"; do
		if [ -x "${path}/${tool}" ]; then
			found="${path}/${tool}"
			break
		fi
	done

	#
	# Tool not found
	#
	if [ -z "${found}" ]; then
		break
	fi

	#
	# Create or update symlink
	#
	ln -sf "${found}" "${UD_EXFAT_DIR}/${tool}"
done

echo ""
echo "-----------------------------------------------------------"
echo " &name; has been installed."
echo " Copyright 2019-2026, &author;"
echo " Version: &version;"
echo "-----------------------------------------------------------"
echo ""
</INLINE>
</FILE>

<!--
The 'remove' script.
-->
<FILE Run="/bin/bash" Method="remove">
<INLINE>
echo "Removing packages..."

#
# Remove all installed packages.
#
removepkg hfsprogs-332.25-x86_64-2sl >/dev/null
removepkg exfat-utils-1.3.0-x86_64-1_slonly >/dev/null
removepkg fuse-exfat-1.3.0-x86_64-1_slonly.txz >/dev/null
removepkg libbsd-0.12.2-x86_64-2cf.txz >/dev/null
removepkg libmd-1.1.0-x86_64-1cf.txz >/dev/null
removepkg apfsfuse-v20230312-x86_64-1.txz >/dev/null

#
# Remove possible leftovers
#
rm -rf /usr/local/emhttp/plugins/&plugin;

#
# Remove plugin related directories
#
rm -rf	/usr/local/sbin/ud-exfat/

echo ""
echo "-----------------------------------------------------------"
echo " &name; has been uninstalled."
echo "-----------------------------------------------------------"
echo ""

</INLINE>
</FILE>

</PLUGIN>
