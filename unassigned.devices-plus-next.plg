<!--
The 'pre-install' script.
-->
<FILE Run="/bin/bash">
<INLINE>
#
# Unassigned Devices must be installed.
#
if [ ! -f /boot/config/plugins/unassigned.devices-next.plg ] || \
   [ ! -d /usr/local/emhttp/plugins/unassigned.devices ]; then
	echo ""
	echo "-----------------------------------------------------------"
	echo " &name; has not been installed!"
	echo ""
	echo " Install the Unassigned Devices - Next plugin first."
	echo "-----------------------------------------------------------"
	echo ""
	exit 1
fi

#
# The previous unassigned devices plus plugin cannot be installed.
#
if [ -f /boot/config/plugins/&plugin;.plg ] ; then
echo ""
echo "-----------------------------------------------------------"
echo " &name; has not been installed!"
echo ""
echo " The previous Unassigned Devices Plus plugin is installed."
echo ""
echo " You must uninstall the Unassigned Devices plugin"
echo " before installing Unassigned Devices - Next."
echo ""
echo "-----------------------------------------------------------"
echo ""
exit 1
fi

#
# Remove emhttp files so we can re-install.
#
rm -rf /usr/local/emhttp/plugins/&plugin;/* 2>/dev/null
</INLINE>
</FILE>

