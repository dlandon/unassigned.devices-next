<!--
The 'pre-install' script.
-->
<FILE Run="/bin/bash">
<INLINE>
#
# Remove emhttp files so we can re-install.
#
rm -rf /usr/local/emhttp/plugins/&plugin;/* 2>/dev/null

#
# Remove old 'bundle' files.
#
rm -f $(ls /boot/config/plugins/&plugin;/&name;*.tgz 2>/dev/null | grep -v '&version;')
</INLINE>
</FILE>

<!--
The 'post-install' script.
-->
<FILE Run="/bin/bash">
<INLINE>
unsupported="/var/state/&plugin;/unsupported"

#
# Creating some directories
#
mkdir -p /tmp/preclear/ /tmp/.preclear/ /usr/local/bin/ /var/state/&plugin;/ /var/log/preclear/

echo "Checking tmux operation..."

#
# Fix tmux tmp directory if needed
#
if [ ! -d "/tmp/tmux-0" ]; then
	mkdir /tmp/tmux-0
fi
chmod 700 /tmp/tmux-0
chown -R root:root /tmp/tmux-0

#
# Verify if tmux is working correctly
#
/usr/bin/tmux new-session -d -x 140 -y 200 -s "install_test_session" &amp;>/dev/null
sleep 0.5
/usr/bin/tmux kill-session -t "install_test_session" &amp;>/dev/null
if [ $? -ne 0 ]; then
	echo "tmux is not working properly" | logger -t "root: plugin: &plugin;.plg"
	touch "$unsupported"
fi

#
# Create plugin directory
#
mkdir -p /boot/config/plugins/&plugin;

#
# Install the 'bundle'.
#
tar -xf /boot/config/plugins/&plugin;/&name;-&version;.tgz -C /usr/local/emhttp/plugins 2>/dev/null

#
# Fix permissions of executable files
#
chmod +x /usr/local/emhttp/plugins/&plugin;/scripts/* /usr/local/emhttp/plugins/&plugin;/event/*

#
# Make sure log file exists
#
touch /var/log/preclear/preclear.log

#
# Set correct terminal type for TMUX
#
echo "set -g default-terminal 'linux'" > /root/.tmux.conf

#
# Set default terminal size for TMUX
#
echo "set -g default-size 100x50" >> /root/.tmux.conf

#
# Create a symlink to diskinfo
#
ln -sf /usr/local/emhttp/plugins/&plugin;/scripts/rc.diskinfo /etc/rc.d/rc.diskinfo

#
# Fix permissions of executable files
#
chmod +x /usr/local/emhttp/plugins/&plugin;/scripts/* /usr/local/emhttp/plugins/&plugin;/event/*

#
# Initiate a hot plug event for unassigned devices and preclear
#
echo "" > /tmp/unassigned.devices/hotplug_event

#
# Add ignore rule to Unraid Flash Backup
#
echo "*.resume" > /boot/config/plugins/&plugin;/.gitignore

#
# Run diskinfo to get the initial unassigned devices information.
#
/etc/rc.d/rc.diskinfo force

echo ""
echo "-----------------------------------------------------------"
echo " &name; has been installed."
echo " Copyright 2022-2026, &author;"
echo " Version: &version;"
echo "-----------------------------------------------------------"
echo ""
</INLINE>
</FILE>

<!--
The 'remove' script.
-->
<FILE Run="/bin/bash" Method="remove">
<INLINE>

#
# kill all preclear sessions
#
/usr/local/emhttp/plugins/&plugin;/scripts/clear_preclear.sh

#
# Remove diskinfo
#
rm -rf /var/local/emhttp/plugins/diskinfo/diskinfo.json /etc/rc.d/rc.diskinfo

#
# Remove plugin
#
rm -rf	/usr/local/emhttp/plugins/&plugin;/

#
# Remove plugin related files
#
rm -rf	/usr/local/bin/preclear \
		/var/run/preclear_queue.pid \
		/var/log/preclear/preclear.log

#
# Remove plugin related directories
#
rm -rf	/var/state/&plugin; \
		/tmp/preclear/ \
		/tmp/.preclear/

#
# Remove the unassigned devices preclear 'bundle' so it will be downloaded if re-installed.
#
rm -rf /boot/config/plugins/&plugin;/&name;-&version;.tgz

echo ""
echo "-----------------------------------------------------------"
echo " &name; has been uninstalled."
echo " Version: &version;"
echo "-----------------------------------------------------------"
echo ""
</INLINE>
</FILE>

</PLUGIN>
