<?xml version='1.0' standalone='yes'?>
<!DOCTYPE PLUGIN [
<!ENTITY name		"unassigned.devices.preclear-next">
<!ENTITY plugin		"unassigned.devices.preclear">
<!ENTITY author		"dlandon">
<!ENTITY version	"2026.03.27">
<!ENTITY launch		"Tools/Preclear">
<!ENTITY gitURL		"https://raw.githubusercontent.com/&author;/unassigned.devices-next/master">
<!ENTITY tgzURL		"https://raw.githubusercontent.com/&author;/unassigned.devices-next/v&version;">
<!ENTITY pluginURL	"&gitURL;/&name;.plg">
<!ENTITY supportURL	"https://github.com/dlandon/unassigned.devices-next/discussions/">
<!ENTITY packages	"/boot/config/plugins/&plugin;/packages">
<!ENTITY MD5		"f3fa138b0ebd8fffcfe419d0f201c5fa">
]>
<PLUGIN name="&plugin;"
		author="&author;"
		launch="&launch;"
		version="&version;"
		pluginURL="&pluginURL;"
		support="&supportURL;"
		icon="icon-preclear"
		min="6.12.0">

<CHANGES>
###&name;
###&version;
- Notice: Initial release under the new license.
- Notice: Minimum Unraid version changed to 6.12.  There have been too many UI changes to maintain backwards compatibility beyond 6.12.
- Fix: Tooltip fixes.
- Fix: Footer icon not showing when preclearing in Unraid 7.2.
- Fix: UI changes for Unraid 7.2.
- Fix: Adjust SweetAlert2 dialogs for black, gray, and azure color themes.
- Fix: Move action buttons from the tab to the table caption.
- Fix: Typo in preclear script.
- Fix: Refactor read and write disk routines to improve speed, robustness, and maintainability.
- Fix: Pause and resume not working properly.
- Rem: Unneeded docker style sheet reference.
- Rem: The tmpfs write buffers in tmpfs have been removed.  This has caused memory exhausted errors at times and are not really necessary.
- Add: Utempter 1.2.3 for 7.2 and later.
- Add: Move packages to a separate folder in the preclear plugin on flash device.
- Add: Ensure all disk reads and writes stop if the disk fails.
- Add: Add SMART check every 15 minutes while writing to confirm disk does not have issues and immediately stop if the disk is failing.
</CHANGES>

