<!--
The 'pre-install' script.
-->
<FILE Run="/bin/bash">
<INLINE>
#
# Unassigned Devices next must be installed.
#
# Check for UD Next plugin file on flash
# Check for installed UD plugin directory (shared by legacy and Next)
#
if [ ! -f /boot/config/plugins/unassigned.devices-next.plg ] || \
   [ ! -d /usr/local/emhttp/plugins/unassigned.devices ]; then
	echo ""
	echo "-----------------------------------------------------------"
	echo " &name; has not been installed!"
	echo ""
	echo " Install the Unassigned Devices - Next plugin first."
	echo "-----------------------------------------------------------"
	echo ""
	exit 1
fi

#
# The previous UD preclear plug cannot be installed.
#
if [ -f /boot/config/plugins/&plugin;.plg ] ; then
echo ""
echo "-----------------------------------------------------------"
echo " &name; has not been installed!"
echo ""
echo " The previous Unassigned Devices Preclear plugin is installed."
echo ""
echo " You must uninstall the Unassigned Devices Preclear plugin"
echo " before installing Unassigned Devices Preclear - Next."
echo ""
echo "-----------------------------------------------------------"
echo ""
exit 1
fi

#
# The legacy preclear plug cannot be installed.
#
if [ -f /boot/config/plugins/preclear.disk.plg ] ; then
echo ""
echo "-----------------------------------------------------------"
echo " &name; has not been installed!"
echo ""
echo " The Preclear Disk plugin is installed."
echo ""
echo " You must uninstall the Preclear Disk plugin before"
echo " installing Unassigned Devices Preclear - Next."
echo ""
echo "-----------------------------------------------------------"
echo ""
exit 1
fi
</INLINE>
</FILE>

<!--
Get the plugin bundle.
-->
<FILE Name="/boot/config/plugins/&plugin;/&name;-&version;.tgz">
<URL>"&tgzURL;/&name;-&version;.tgz"</URL>
<MD5>&MD5;</MD5>
</FILE>

